{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_cfw_schedule": {
          "block": {
            "attributes": {
              "description": {
                "type": "string",
                "optional": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "name": {
                "type": "string",
                "required": true
              },
              "object_id": {
                "type": "string",
                "required": true
              },
              "ref_count": {
                "type": "number",
                "computed": true
              },
              "region": {
                "type": "string",
                "computed": true
              }
            },
            "block_types": {
              "absolute": {
                "block": {
                  "attributes": {
                    "end_time": {
                      "type": "number",
                      "optional": true,
                      "computed": true
                    },
                    "start_time": {
                      "type": "number",
                      "optional": true,
                      "computed": true
                    }
                  }
                },
                "nesting_mode": "list",
                "max_items": 1
              },
              "periodic": {
                "block": {
                  "attributes": {
                    "end_time": {
                      "type": "string",
                      "required": true
                    },
                    "end_week": {
                      "type": "number",
                      "optional": true,
                      "computed": true
                    },
                    "start_time": {
                      "type": "string",
                      "required": true
                    },
                    "start_week": {
                      "type": "number",
                      "optional": true,
                      "computed": true
                    },
                    "type": {
                      "type": "number",
                      "required": true
                    },
                    "week_mask": {
                      "type": [
                        "list",
                        "number"
                      ],
                      "optional": true,
                      "computed": true
                    }
                  }
                },
                "nesting_mode": "list"
              }
            }
          },
          "product": {
            "short": "CFW",
            "name": "Cloud Firewall",
            "catalog": "Security & Compliance",
            "name_cn": "云防火墙",
            "catalog_cn": "安全与合规"
          }
        }
      }
    }
  }
}
