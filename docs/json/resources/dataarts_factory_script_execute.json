{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_dataarts_factory_script_execute": {
          "block": {
            "attributes": {
              "id": {
                "type": "string",
                "computed": true
              },
              "message": {
                "type": "string",
                "description": "The message when the script instance execution fails.",
                "computed": true
              },
              "params": {
                "type": "string",
                "description": "The execution parameters passed to the script content, in JSON format.",
                "optional": true
              },
              "region": {
                "type": "string",
                "description": "The region where the workspace is located.",
                "computed": true
              },
              "script_name": {
                "type": "string",
                "description": "The name of the script to be executed.",
                "required": true
              },
              "status": {
                "type": "string",
                "description": "The execution status of the script instance.",
                "computed": true
              },
              "workspace_id": {
                "type": "string",
                "description": "The ID of the workspace to which the script belongs.",
                "required": true
              }
            }
          },
          "product": {
            "short": "DataArtsStudio",
            "name": "DataArts Studio",
            "catalog": "Analytics",
            "name_cn": "数据治理中心",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
