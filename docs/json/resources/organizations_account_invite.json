{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_organizations_account_invite": {
          "block": {
            "attributes": {
              "account_id": {
                "type": "string",
                "description": "The ID of the target account.",
                "required": true,
                "forcenew": true
              },
              "created_at": {
                "type": "string",
                "description": "The date and time when an invitation (handshake) request was made.",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "master_account_id": {
                "type": "string",
                "description": "The unique ID of the organization's management account.",
                "computed": true
              },
              "master_account_name": {
                "type": "string",
                "description": "The name of the organization's management account.",
                "computed": true
              },
              "organization_id": {
                "type": "string",
                "description": "The ID of the organization.",
                "computed": true
              },
              "remove_account_on_destroy": {
                "type": "bool",
                "description": "Whether to remove the invited account when delete the invitation (handshake).",
                "optional": true
              },
              "status": {
                "type": "string",
                "description": "The current state of the invitation (handshake).",
                "computed": true
              },
              "updated_at": {
                "type": "string",
                "description": "The date and time when an invitation (handshake) request was accepted,\ncanceled, declined, or expired.",
                "computed": true
              },
              "urn": {
                "type": "string",
                "description": "The uniform resource name of the invitation",
                "computed": true
              }
            }
          },
          "product": {
            "short": "Organizations",
            "name": "Organizations",
            "catalog": "Management & Governance",
            "name_cn": "组织",
            "catalog_cn": "管理与监管"
          }
        }
      }
    }
  }
}
