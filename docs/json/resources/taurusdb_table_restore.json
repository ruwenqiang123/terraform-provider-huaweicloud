                          "old_name": {
                            "type": "string",
                            "required": true,
                            "forcenew": true
                          }
                        }
                      },
                      "nesting_mode": "list",
                      "forcenew": true,
                      "min_items": 1
                    }
                  }
                },
                "nesting_mode": "list",
                "forcenew": true,
                "min_items": 1
              }
            }
          }
        }
      }
    }
  }
}
