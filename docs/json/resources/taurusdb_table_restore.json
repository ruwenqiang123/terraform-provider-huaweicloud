{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_taurusdb_table_restore": {
          "block": {
            "attributes": {
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_id": {
                "type": "string",
                "required": true,
                "forcenew": true
              },
              "last_table_info": {
                "type": "string",
                "optional": true,
                "forcenew": true
              },
              "region": {
                "type": "string"
              },
              "restore_time": {
                "type": "string",
                "required": true,
                "forcenew": true
              }
            },
            "block_types": {
