{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_dataarts_factory_job_export": {
          "block": {
            "attributes": {
              "export_depend": {
                "type": "bool",
                "description": "Whether to export the scripts and resources depended on by the job.",
                "optional": true,
                "computed": true
              },
              "export_status": {
                "type": "string",
                "description": "The job status to export.",
                "optional": true
              },
              "folder_path": {
                "type": "string",
                "description": "The folder path suffix in the returned OBS path relative to the input OBS path.",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "job_name": {
                "type": "string",
                "description": "The job name.",
                "required": true
              },
              "obs_path": {
                "type": "string",
                "description": "The OBS target path for storing the exported job package.",
                "required": true
              },
              "region": {
                "type": "string",
                "description": "The region where the job is located.",
                "computed": true
              },
              "workspace_id": {
                "type": "string",
                "description": "The workspace ID to which the job belongs.",
                "optional": true,
                "computed": true
              }
            }
          },
          "product": {
            "short": "DataArtsStudio",
            "name": "DataArts Studio",
            "catalog": "Analytics",
            "name_cn": "数据治理中心",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
