{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_cse_microservice_engine": {
          "block": {
            "attributes": {
              "admin_pass": {
                "type": "string",
                "description": "The administrator account password of the microservice engine.",
                "optional": true,
                "sensitive": true
              },
              "auth_type": {
                "type": "string",
                "description": "The authentication type of the microservice engine.",
                "required": true
              },
              "availability_zones": {
                "type": [
                  "set",
                  "string"
                ],
                "description": "The availability zones where the microservice engine is deployed.",
                "optional": true,
                "computed": true
              },
              "config_center_addresses": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "private": "string",
                      "public": "string"
                    }
                  ]
                ],
                "description": "The config center addresses of the microservice engine.",
                "computed": true
              },
              "description": {
                "type": "string",
                "description": "The description of the microservice engine.",
                "optional": true,
                "computed": true
              },
              "eip_id": {
                "type": "string",
                "description": "The EIP ID bound to the microservice engine.",
                "optional": true
              },
              "enterprise_project_id": {
                "type": "string",
                "description": "The enterprise project ID to which the microservice engine belongs.",
                "optional": true,
                "computed": true
              },
              "extend_params": {
                "type": [
                  "map",
                  "string"
                ],
                "description": "The extended parameters of the microservice engine.",
                "optional": true,
                "computed": true
              },
              "flavor": {
                "type": "string",
                "description": "The flavor of the microservice engine.",
                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_limit": {
                "type": "number",
                "description": "The maximum number of the microservice instance resources.",
                "computed": true
              },
              "max_retries": {
                "type": "number",
                "description": "The maximum number of retries for the microservice engine creation.",
                "optional": true
              },
              "name": {
                "type": "string",
                "description": "The name of the microservice engine.",
                "required": true
              },
              "network_id": {
                "type": "string",
                "description": "The network ID of the subnet to which the microservice engine belongs.",
                "required": true
              },
              "region": {
                "type": "string",
                "description": "The region where the microservice engine is located.",
                "computed": true
              },
              "service_limit": {
                "type": "number",
                "description": "The maximum number of the microservice resources.",
                "computed": true
              },
              "service_registry_addresses": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "private": "string",
                      "public": "string"
                    }
                  ]
                ],
                "description": "The service registry addresses of the microservice engine.",
                "computed": true
              },
              "tags": {
                "type": [
                  "map",
                  "string"
                ],
                "description": "The key/value pairs to associate with the microservice engine.",
                "optional": true,
                "computed": true
              },
              "version": {
                "type": "string",
                "description": "The version of the microservice engine.",
                "optional": true,
                "default": "CSE2"
              }
            }
          },
          "product": {
            "short": "CSE",
            "name": "Cloud Service Engine",
            "catalog": "Middleware",
            "name_cn": "微服务引擎",
            "catalog_cn": "应用中间件"
          }
        }
      }
    }
  }
}
