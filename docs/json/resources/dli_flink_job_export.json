{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_dli_flink_job_export": {
          "block": {
            "attributes": {
              "id": {
                "type": "string",
                "computed": true
              },
              "job_ids": {
                "type": [
                  "list",
                  "number"
                ],
                "description": "The set of job IDs to be exported.",
                "required": true
              },
              "obs_path": {
                "type": "string",
                "description": "The OBS save path for the exported job file.",
                "required": true
              },
              "region": {
                "type": "string",
                "description": "The region where to export flink jobs.",
                "computed": true
              }
            }
          },
          "product": {
            "short": "DLI",
            "name": "Data Lake Insight",
            "catalog": "Analytics",
            "name_cn": "数据湖探索",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
