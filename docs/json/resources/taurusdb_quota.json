{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_taurusdb_quota": {
          "block": {
            "attributes": {
              "availability_instance_quota": {
                "type": "number",
                "computed": true
              },
              "availability_ram_quota": {
                "type": "number",
                "computed": true
              },
              "availability_vcpus_quota": {
                "type": "number",
                "computed": true
              },
              "enterprise_project_id": {
                "type": "string",
                "required": true,
                "forcenew": true
              },
              "enterprise_project_name": {
                "type": "string",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_quota": {
                "type": "number",
                "optional": true,
                "default": -1
              },
              "ram_quota": {
                "type": "number",
                "optional": true,
                "default": -1
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "vcpus_quota": {
                "type": "number",
                "optional": true,
                "default": -1
              }
            }
          }
        }
      }
    }
  }
}
