{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_organizations_organization": {
          "block": {
            "attributes": {
              "created_at": {
                "type": "string",
                "description": "The time when the organization was created.",
                "computed": true
              },
              "enabled_policy_types": {
                "type": [
                  "set",
                  "string"
                ],
                "description": "The list of policy types to be enabled in the organization root.",
                "optional": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "master_account_id": {
                "type": "string",
                "description": "The unique ID of the organization's management account.",
                "computed": true
              },
              "master_account_name": {
                "type": "string",
                "description": "The name of the organization's management account.",
                "computed": true
              },
              "root_id": {
                "type": "string",
                "description": "The ID of the root.",
                "computed": true
              },
              "root_name": {
                "type": "string",
                "description": "The name of the root.",
                "computed": true
              },
              "root_tags": {
                "type": [
                  "map",
                  "string"
                ],
                "description": "The key/value pairs to be attached to the root.",
                "optional": true,
                "computed": true
              },
              "root_urn": {
                "type": "string",
                "description": "The urn of the root.",
                "computed": true
              },
              "urn": {
                "type": "string",
                "description": "The uniform resource name of the organization.",
                "computed": true
              }
            }
          },
          "product": {
            "short": "Organizations",
            "name": "Organizations",
            "catalog": "Management & Governance",
            "name_cn": "组织",
            "catalog_cn": "管理与监管"
          }
        }
      }
    }
  }
}
