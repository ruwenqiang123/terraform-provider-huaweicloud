{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_taurusdb_diagnosis_instances": {
          "block": {
            "attributes": {
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_infos": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "instance_id": "string",
                      "master_node_id": "string"
                    }
                  ]
                ],
                "description": "Indicates the information about the abnormal instances.",
                "computed": true
              },
              "metric_name": {
                "type": "string",
                "description": "Specifies the metric name.",
                "required": true
              },
              "region": {
                "type": "string",
                "computed": true
              }
            }
          }
        }
      }
    }
  }
}
