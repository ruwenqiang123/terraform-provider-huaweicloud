{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_dws_cluster_database_schemas": {
          "block": {
            "attributes": {
              "cluster_id": {
                "type": "string",
                "description": "The ID of the cluster to be queried.",
                "required": true
              },
              "database_name": {
                "type": "string",
                "description": "The name of the database to be queried.",
                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "keywords": {
                "type": "string",
                "description": "The keywords used for fuzzy query.",
                "optional": true
              },
              "region": {
                "type": "string",
                "description": "The region where the database schemas are located.",
                "computed": true
              },
              "schemas": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "database_name": "string",
                      "dn_num": "number",
                      "max_dn": "string",
                      "max_value": "number",
                      "min_dn": "string",
                      "min_value": "number",
                      "perm_space": "number",
                      "schema_name": "string",
                      "skew_percent": "number",
                      "total_value": "number"
                    }
                  ]
                ],
                "description": "The list of the database schemas that matched filter parameters.",
                "computed": true
              },
              "sort_dir": {
                "type": "string",
                "description": "The direction of sorting query results.",
                "optional": true
              },
              "sort_key": {
                "type": "string",
                "description": "The field used to sort query results.",
                "optional": true
              }
            }
          },
          "product": {
            "short": "DWS",
            "name": "Data Warehouse Service",
            "catalog": "Analytics",
            "name_cn": "数据仓库服务",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
