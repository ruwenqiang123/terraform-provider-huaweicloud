{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_oms_bucket_cdn_info": {
          "block": {
            "attributes": {
              "ak": {
                "type": "string",
                "required": true,
                "sensitive": true
              },
              "app_id": {
                "type": "string",
                "optional": true
              },
              "bucket": {
                "type": "string",
                "required": true
              },
              "checked_keys": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "is_etag_matching": "bool",
                      "is_object_existing": "bool",
                      "key": "string"
                    }
                  ]
                ],
                "computed": true
              },
              "cloud_type": {
                "type": "string",
                "required": true
              },
              "connection_string": {
                "type": "string",
                "optional": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "is_download_available": {
                "type": "bool",
                "computed": true
              },
              "is_same_cloud_type": {
                "type": "bool",
                "computed": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "sk": {
                "type": "string",
                "required": true,
                "sensitive": true
              }
            },
            "block_types": {
              "prefix": {
                "block": {
                  "attributes": {
                    "keys": {
                      "type": [
                        "list",
                        "string"
                      ],
                      "required": true
                    }
                  }
                },
                "nesting_mode": "list"
              },
              "source_cdn": {
                "block": {
                  "attributes": {
                    "authentication_key": {
                      "type": "string",
                      "optional": true
                    },
                    "authentication_type": {
                      "type": "string",
                      "required": true
                    },
                    "domain": {
                      "type": "string",
                      "required": true
                    },
                    "protocol": {
                      "type": "string",
                      "required": true
                    }
                  }
                },
                "nesting_mode": "list",
                "min_items": 1
              }
            }
          },
          "product": {
            "short": "OMS",
            "name": "Object Storage Migration Service",
            "catalog": "Migration",
            "name_cn": "对象存储迁移服务",
            "catalog_cn": "迁移"
          }
        }
      }
    }
  }
}
