{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_rfs_execution_plan_prices": {
          "block": {
            "attributes": {
              "currency": {
                "type": "string",
                "computed": true
              },
              "execution_plan_id": {
                "type": "string",
                "optional": true
              },
              "execution_plan_name": {
                "type": "string",
                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "items": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "index": "string",
                      "module_address": "string",
                      "resource_name": "string",
                      "resource_price": [
                        "list",
                        [
                          "object",
                          {
                            "best_discount_price": "number",
                            "best_discount_type": "number",
