                      ],
                      "resource_type": "string",
                      "supported": "bool",
                      "unsupported_message": "string"
                    }
                  ]
                ],
                "computed": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "stack_id": {
                "type": "string",
                "optional": true
              },
              "stack_name": {
                "type": "string",
                "required": true
              }
            }
          },
          "product": {
            "short": "RFS",
            "name": "Resource Formation",
            "catalog": "Management & Governance",
            "name_cn": "资源编排服务",
            "catalog_cn": "管理与监管"
