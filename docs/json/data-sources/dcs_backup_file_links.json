{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_dcs_backup_file_links": {
          "block": {
            "attributes": {
              "backup_id": {
                "type": "string",
                "required": true
              },
              "bucket_name": {
                "type": "string",
                "computed": true
              },
              "expiration": {
                "type": "number",
                "required": true
              },
              "file_path": {
                "type": "string",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_id": {
                "type": "string",
                "required": true
              },
              "links": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "file_name": "string",
                      "link": "string"
                    }
                  ]
                ],
                "computed": true
              },
              "region": {
                "type": "string",
                "computed": true
              }
            }
          },
          "product": {
            "short": "DCS",
            "name": "Distributed Cache Service",
            "catalog": "Middleware",
            "name_cn": "分布式缓存服务",
            "catalog_cn": "应用中间件"
          }
        }
      }
    }
  }
}
