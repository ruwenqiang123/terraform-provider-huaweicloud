                      "finished_time": "string",
                      "job_id": "string",
                      "job_name": "string",
                      "job_progress": "number",
                      "job_result": "string",
                      "job_state": "string",
                      "job_type": "string",
                      "launcher_id": "string",
                      "properties": "string",
                      "queue": "string",
                      "started_time": "string",
                      "submitted_time": "string",
                      "tracking_url": "string",
                      "user": "string"
                    }
                  ]
                ],
                "description": "The list of jobs that match the filter parameters.",
                "computed": true
              },
              "queue": {
                "type": "string",
