{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_mapreduce_cluster_jobs": {
          "block": {
            "attributes": {
              "cluster_id": {
                "type": "string",
