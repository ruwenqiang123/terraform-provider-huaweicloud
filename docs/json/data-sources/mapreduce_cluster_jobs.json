                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "job_id": {
                "type": "string",
                "description": "The ID of the job.",
                "optional": true
              },
              "job_name": {
                "type": "string",
                "description": "The name of the job.",
                "optional": true
              },
              "job_result": {
                "type": "string",
                "description": "The execution result of the job.",
                "optional": true
              },
              "job_state": {
                "type": "string",
                "description": "The execution status of the job.",
                "optional": true
              },
              "job_type": {
                "type": "string",
                "description": "The type of the job.",
                "optional": true
              },
              "jobs": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "app_id": "string",
