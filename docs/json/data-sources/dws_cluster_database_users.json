{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_dws_cluster_database_users": {
          "block": {
            "attributes": {
              "cluster_id": {
                "type": "string",
                "description": "The ID of the cluster to be queried.",
                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "region": {
                "type": "string",
                "description": "The region where the database users are located.",
                "computed": true
              },
              "type": {
                "type": "string",
                "description": "The object type to be queried.",
                "optional": true
              },
              "user_type": {
                "type": "string",
                "description": "The user type to be queried.",
                "optional": true
              },
              "users": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "login": "bool",
                      "name": "string",
                      "user_type": "string"
                    }
                  ]
                ],
                "description": "The list of the database users that matched filter parameters.",
                "computed": true
              }
            }
          },
          "product": {
            "short": "DWS",
            "name": "Data Warehouse Service",
            "catalog": "Analytics",
            "name_cn": "数据仓库服务",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
