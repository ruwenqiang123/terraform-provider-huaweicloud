{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_taurusdb_restore_time_ranges": {
          "block": {
            "attributes": {
              "date": {
                "type": "string",
                "description": "Specifies the date to be queried.",
                "optional": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_id": {
                "type": "string",
                "description": "Specifies the ID of the TaurusDB instance.",
                "required": true
              },
              "region": {
                "type": "string",
                "description": "Specifies the region in which to query the resource. If omitted, the provider-level region will be used.",
                "computed": true
              },
              "restore_times": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "end_time": "number",
                      "start_time": "number"
                    }
                  ]
                ],
                "description": "Indicates the list of restoration time ranges.",
                "computed": true
              }
            }
          }
        }
      }
    }
  }
}
