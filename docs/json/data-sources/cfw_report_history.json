{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_cfw_report_history": {
          "block": {
            "attributes": {
              "fw_instance_id": {
                "type": "string",
                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "records": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "report_id": "string",
                      "send_time": "number",
                      "statistic_period": [
                        "list",
                        [
                          "object",
                          {
                            "end_time": "number",
                            "start_time": "number"
                          }
                        ]
                      ]
                    }
                  ]
                ],
                "computed": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "report_profile_id": {
                "type": "string",
                "required": true
              }
            }
          },
          "product": {
            "short": "CFW",
            "name": "Cloud Firewall",
            "catalog": "Security & Compliance",
            "name_cn": "云防火墙",
            "catalog_cn": "安全与合规"
          }
        }
      }
    }
  }
}
