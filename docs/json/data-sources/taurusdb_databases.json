{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_taurusdb_databases": {
          "block": {
            "attributes": {
              "character_set": {
                "type": "string",
                "description": "Specifies the database character set,",
                "optional": true
              },
              "databases": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "character_set": "string",
                      "description": "string",
                      "name": "string",
                      "users": [
                        "list",
                        [
                          "object",
                          {
                            "host": "string",
                            "name": "string",
                            "readonly": "bool"
                          }
                        ]
                      ]
                    }
                  ]
                ],
                "description": "Indicates the list databases.",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_id": {
                "type": "string",
                "description": "Specifies the ID of TaurusDB Instance.",
                "required": true
              },
              "name": {
                "type": "string",
                "description": "Specifies the database name.",
                "optional": true
              },
              "region": {
                "type": "string",
                "description": "Specifies the region in which to query the resource. If omitted, the provider-level region will be used.",
                "computed": true
              }
            }
          }
        }
      }
    }
  }
}
