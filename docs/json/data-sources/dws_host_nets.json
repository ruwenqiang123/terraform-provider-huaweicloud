{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_dws_host_nets": {
          "block": {
            "attributes": {
              "cluster_id": {
                "type": "string",
                "description": "The cluster ID to be queried.",
                "optional": true
              },
              "host_nets": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "ctime": "number",
                      "host_id": "number",
                      "host_name": "string",
                      "instance_name": "string",
                      "interface_name": "string",
                      "io_rate": "number",
                      "recv_drop": "number",
                      "recv_packets": "number",
                      "recv_rate": "number",
                      "send_packets": "number",
                      "send_rate": "number",
                      "speed": "number",
                      "up": "bool",
                      "virtual_cluster_id": "number"
                    }
                  ]
                ],
                "description": "The list of the host nets that matched filter parameters.",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_name": {
                "type": "string",
                "description": "The instance name to be queried.",
                "optional": true
              },
              "region": {
                "type": "string",
                "description": "The region where the host nets are located.",
                "computed": true
              }
            }
          },
          "product": {
            "short": "DWS",
            "name": "Data Warehouse Service",
            "catalog": "Analytics",
            "name_cn": "数据仓库服务",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
