{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_mapreduce_availability_zones": {
          "block": {
            "attributes": {
              "available_zones": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "az_category": "number",
                      "az_code": "string",
                      "az_group_id": "string",
                      "az_id": "string",
                      "az_name": "string",
                      "az_tags": [
                        "list",
                        [
                          "object",
                          {
                            "alias": "string",
                            "mode": "string",
                            "public_border_group": "string"
                          }
                        ]
                      ],
                      "az_type": "string",
                      "charge_policy": "string",
                      "id": "string",
                      "region_id": "string",
                      "status": "string"
                    }
                  ]
                ],
                "description": "The availability zone list that matched the filter parameters.",
                "computed": true
              },
              "default_az_code": {
                "type": "string",
                "description": "The default availability zone code.",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "region": {
                "type": "string",
                "description": "The region where the availability zones are located.",
                "computed": true
              },
              "scope": {
                "type": "string",
                "description": "The scope of the availability zone.",
                "optional": true
              },
              "support_physical_az_group": {
                "type": "bool",
                "description": "Whether the physical availability zone grouping is supported.",
                "computed": true
              }
            }
          },
          "product": {
            "short": "MRS",
            "name": "MapReduce Service",
            "catalog": "Analytics",
            "name_cn": "MapReduce服务",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
