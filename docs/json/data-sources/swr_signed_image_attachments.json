{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_swr_signed_image_attachments": {
          "block": {
            "attributes": {
              "accessories": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "created_at": "string",
                      "domain_id": "string",
                      "id": "number",
                      "namespace_name": "string",
                      "repo_name": "string",
                      "sig_digest": "string",
                      "sig_tag": "string",
                      "size": "number",
                      "target_digest": "string",
                      "type": "string",
                      "updated_at": "string"
                    }
                  ]
                ],
                "description": "The list of attachments of the signed image.",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "namespace": {
                "type": "string",
                "description": "Specifies the namespace (organization) name of the signed image belongs.",
                "required": true
              },
              "region": {
                "type": "string",
                "description": "Specifies the region in which to query the data source.",
                "computed": true
              },
              "repository": {
                "type": "string",
                "description": "Specifies the repository name of the signed image.",
                "required": true
              },
              "tag": {
                "type": "string",
                "description": "Specifies the tag of the signed image.",
                "required": true
              }
            }
          },
          "product": {
            "short": "SWR",
            "name": "Software Repository for Container",
            "catalog": "Containers",
            "name_cn": "容器镜像服务",
            "catalog_cn": "容器"
          }
        }
      }
    }
  }
}
