                      "schedule_config": [
                        "list",
                        [
                          "object",
                          {
                            "cron_expression": "string",
                            "enabled": "number",
                            "end_time": "string",
                            "interval": "string",
                            "job_id": "number",
                            "max_time_out": "number",
                            "schedule_type": "string",
