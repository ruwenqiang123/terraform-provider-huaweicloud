              },
              "workspace_id": {
                "type": "string",
                "description": "The ID of the workspace to which the metadata tasks belongs.",
                "required": true
              }
            }
          },
          "product": {
            "short": "DataArtsStudio",
            "name": "DataArts Studio",
            "catalog": "Analytics",
            "name_cn": "数据治理中心",
